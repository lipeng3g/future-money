{
  "name": "future-money",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:verify": "node scripts/run-with-log.mjs build.log npm run build && npm run build:check && npm run build:log-check build.log",
    "preview": "vite preview",
    "type-check": "vue-tsc -p tsconfig.app.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm test && npm run type-check && npm run build",
    "smoke": "vitest run src/stores/__tests__/finance-smoke.test.ts src/layouts/__tests__/AppHeaderImportUndo.smoke.test.ts src/stores/__tests__/reconciliation-journey.smoke.test.ts && node scripts/browser-chart-smoke.mjs && node scripts/browser-chart-runtime-failure-smoke.mjs",
    "build:check": "node scripts/check-build-chunks.mjs",
    "build:log-check": "node scripts/check-build-log.mjs"
  },
  "dependencies": {
    "ant-design-vue": "^4.2.5",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.11",
    "echarts": "^5.5.1",
    "markdown-it": "^14.1.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.28",
    "vue-echarts": "^7.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.14.10",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vitest/coverage-v8": "^1.6.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^24.1.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.2",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.29"
  }
}
