# FutureMoney - example env file
#
# This repo does NOT require env vars to run.
# These are optional toggles for build verification / CI.

# Path to the build log used by scripts/check-build-log.mjs
# BUILD_LOG_PATH=./build.log

# Optional strict modes for CI:
# - Fail the build if Vite reports any >500kB (minified) chunks.
# CI_STRICT_VITE_OVERSIZE=0

# - Fail the build if budget warnings exist (not only hard failures).
# CI_STRICT_BUILD_BUDGET=0
